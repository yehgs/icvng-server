{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/order/webhook",
      "methods": ["POST"],
      "dest": "index.js",
      "headers": {
        "Content-Type": "application/json"
      }
    },
    {
      "src": "/api/order/paystack-webhook",
      "methods": ["POST"],
      "dest": "index.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["fra1"]
}
